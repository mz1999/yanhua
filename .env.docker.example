# Docker 部署环境变量配置
# 复制此文件为 .env 并填写你的实际配置

# ============================================
# AI API Keys（必需）
# ============================================

# DeepSeek API - 用于生成绘画提示词
DEEPSEEK_API_KEY=your-api-key-here

# 提示词生成服务配置（可选，使用默认值即可）
LLM_API_URL=https://api.siliconflow.cn/v1/chat/completions
LLM_MODEL=Pro/deepseek-ai/DeepSeek-V3.2

# ============================================
# 即梦 API 配置（必需）
# ============================================
#
# 1. 先获取宿主机 IP：
#    ip addr show docker0 | grep inet
#    输出示例：inet 172.17.0.1/16 brd 172.17.255.255 scope global docker0
#    宿主机 IP 就是 172.17.0.1
#
# 2. 确保即梦服务已启动并暴露 8000 端口
#
# 3. 配置 JIMENG_API_URL（将 172.17.0.1 替换为你的实际 IP）
#

JIMENG_API_URL=http://172.17.0.1:8000
JIMENG_API_KEY=your-jimeng-session-id-here

# ============================================
# 应用配置
# ============================================

# 应用 URL（生产环境改为你的域名）
NEXT_PUBLIC_APP_URL=http://localhost:3000
