# 数据库配置
DATABASE_URL="file:./dev.db"

# ============================================
# AI API Keys（必需）
# ============================================

# DeepSeek API - 用于生成绘画提示词
# 获取地址: https://platform.deepseek.com/
# 或使用硅基流动: https://siliconflow.cn/
# 注册后创建 API Key，复制到这里
DEEPSEEK_API_KEY=your-api-key-here

# 提示词生成服务配置（可选）
# 默认使用硅基流动，如需使用官方 DeepSeek API，请修改：
# LLM_API_URL=https://api.deepseek.com/v1/chat/completions
# LLM_MODEL=deepseek-chat
LLM_API_URL=https://api.siliconflow.cn/v1/chat/completions
# 注意：硅基流动上需要 Pro/ 前缀的模型才支持推理输出
# 支持推理的模型：Pro/deepseek-ai/DeepSeek-V3.2, Pro/deepseek-ai/DeepSeek-R1
# 不支持推理的模型：deepseek-ai/DeepSeek-V3.2 (reasoning_tokens 始终为 0)
LLM_MODEL=Pro/deepseek-ai/DeepSeek-V3.2

# 即梦 Free API - 用于生成图片
# 1. 本地部署 jimeng-free-api-all: https://github.com/zhizinan1997/jimeng-free-api-all
# 2. 启动服务后，在 http://localhost:8001 获取 sessionid
# 3. 将 sessionid 填入下方
JIMENG_API_URL=http://localhost:8000
JIMENG_API_KEY=your-jimeng-session-id-here

# ============================================
# 可选配置
# ============================================

# 应用 URL（用于生成图片时回调）
# 开发环境保持默认即可，生产环境改为你的域名
NEXT_PUBLIC_APP_URL=http://localhost:3000
